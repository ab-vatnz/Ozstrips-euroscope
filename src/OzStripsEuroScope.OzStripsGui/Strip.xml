<StripElementList>
  <!--
    NZ merged strip layout for OzStrips.

    OzStrips supports one 420x84 live layout for every strip state. This version
    keeps the real-strip feel by using a large open taxi/free-text area instead
    of a grid of small boxes.
  -->

  <!-- Left identity block: one visual block with aircraft details over the callsign. -->
  <StripElement>
    <X>0</X>
    <Y>0</Y>
    <W>140</W>
    <H>60</H>
    <Value>ACID</Value>
    <LeftClick>PICK</LeftClick>
    <RightClick>OPEN_FDR</RightClick>
    <BorderColour>#00000000</BorderColour>
    <FontSize>28</FontSize>
  </StripElement>
  <StripElement cockable="true">
    <X>0</X>
    <Y>0</Y>
    <W>34</W>
    <H>14</H>
    <Value>TYPE</Value>
    <LeftClick>OPEN_FDR</LeftClick>
    <BorderColour>#00000000</BorderColour>
    <FontSize>10</FontSize>
  </StripElement>
  <StripElement cockable="true">
    <X>34</X>
    <Y>0</Y>
    <W>16</W>
    <H>14</H>
    <Value>WTC</Value>
    <BorderColour>#00000000</BorderColour>
    <FontSize>10</FontSize>
  </StripElement>
  <StripElement cockable="true">
    <X>92</X>
    <Y>0</Y>
    <W>48</W>
    <H>14</H>
    <Value>ADES</Value>
    <LeftClick>OPEN_FDR</LeftClick>
    <BorderColour>#00000000</BorderColour>
    <FontSize>10</FontSize>
  </StripElement>

  <!-- Runway and level block. Bottom-left is intentionally blank, like the reference strip. -->
  <StripElement>
    <X>140</X>
    <Y>0</Y>
    <W>45</W>
    <H>20</H>
    <Value>RWY</Value>
    <LeftClick>MOD_RWY</LeftClick>
    <FontSize>14</FontSize>
  </StripElement>
  <StripElement>
    <X>140</X>
    <Y>20</Y>
    <W>22</W>
    <H>20</H>
    <Value>RFL</Value>
    <LeftClick>MOD_RFL</LeftClick>
    <Hover>RFL_WARNING</Hover>
    <MiddleClick>INHIBIT_RFL</MiddleClick>
    <FontSize>9</FontSize>
  </StripElement>
  <StripElement>
    <X>162</X>
    <Y>20</Y>
    <W>23</W>
    <H>20</H>
    <Value>CFL</Value>
    <LeftClick>MOD_CFL</LeftClick>
    <FontSize>9</FontSize>
  </StripElement>
  <StripElement>
    <X>140</X>
    <Y>40</Y>
    <W>45</W>
    <H>20</H>
    <Value>SSR</Value>
    <LeftClick>ASSIGN_SSR</LeftClick>
    <Hover>SSR_WARNING</Hover>
    <MiddleClick>INHIBIT_SSR</MiddleClick>
    <FontSize>11</FontSize>
  </StripElement>

  <!-- Restore the broad original taxi/free-text block and its SID presentation. -->
  <StripElement crossable="true">
    <X>185</X>
    <Y>0</Y>
    <W>145</W>
    <H>36</H>
    <Value>GLOP</Value>
    <LeftClick>MOD_GLOP</LeftClick>
    <MiddleClick>INHIBIT_HDG</MiddleClick>
    <FontSize>16</FontSize>
  </StripElement>
  <StripElement>
    <X>185</X>
    <Y>36</Y>
    <W>145</W>
    <H>24</H>
    <Value>SID</Value>
    <LeftClick>MOD_SID</LeftClick>
    <RightClick>SID_TRIGGER</RightClick>
    <Hover>SID_TRIGGER</Hover>
    <MiddleClick>INHIBIT_SID</MiddleClick>
    <FontSize>18</FontSize>
  </StripElement>
  <!-- Ready is a single large square. Stand sits beneath the callsign. -->
  <StripElement>
    <X>330</X>
    <Y>0</Y>
    <W>60</W>
    <H>60</H>
    <Value>READY</Value>
    <LeftClick>SET_READY</LeftClick>
    <MiddleClick>INHIBIT_READY</MiddleClick>
    <FontSize>11</FontSize>
  </StripElement>
  <StripElement>
    <X>0</X>
    <Y>60</Y>
    <W>140</W>
    <H>24</H>
    <Value>STAND</Value>
    <LeftClick>MOD_STD</LeftClick>
    <RightClick>MOD_ALLOCATOR_STD</RightClick>
    <FontSize>14</FontSize>
  </StripElement>

  <!-- Five route waypoints: first route point plus the following four. -->
  <StripElement><X>140</X><Y>60</Y><W>56</W><H>24</H><Value>FIRST_WPT</Value><LeftClick>OPEN_FDR</LeftClick><RightClick>OPEN_REROUTE</RightClick><MiddleClick>INHIBIT_ROUTE</MiddleClick><Hover>ROUTE_WARNING</Hover><FontSize>11</FontSize></StripElement>
  <StripElement><X>196</X><Y>60</Y><W>56</W><H>24</H><Value>WAYPOINT_1</Value><FontSize>11</FontSize></StripElement>
  <StripElement><X>252</X><Y>60</Y><W>56</W><H>24</H><Value>WAYPOINT_2</Value><FontSize>11</FontSize></StripElement>
  <StripElement><X>308</X><Y>60</Y><W>56</W><H>24</H><Value>WAYPOINT_3</Value><FontSize>11</FontSize></StripElement>
  <StripElement><X>364</X><Y>60</Y><W>56</W><H>24</H><Value>WAYPOINT_4</Value><FontSize>11</FontSize></StripElement>
  <StripElement cockable="true">
    <X>0</X>
    <Y>44</Y>
    <W>32</W>
    <H>16</H>
    <Value>FRUL</Value>
    <BorderColour>#00000000</BorderColour>
    <FontSize>10</FontSize>
  </StripElement>
  <StripElement>
    <X>390</X>
    <Y>0</Y>
    <W>30</W>
    <H>30</H>
    <Value>ATIS</Value>
    <LeftClick>ACK_ATIS</LeftClick>
    <FontSize>14</FontSize>
  </StripElement>
  <StripElement cockable="true">
    <X>390</X>
    <Y>30</Y>
    <W>30</W>
    <H>30</H>
    <Value>EOBT</Value>
    <LeftClick>OPEN_PDC</LeftClick>
    <RightClick>OPEN_PM</RightClick>
    <FontSize>12</FontSize>
  </StripElement>
</StripElementList>
