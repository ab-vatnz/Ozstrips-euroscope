<!-- Be very careful editing the OzStrips configuration.
     Do not make changes to this file, place an overwrite file in (PROFILE)/Plugins/AerodromeSettings.xml
     Changes between the two files are not additive. Changes in the Profile directory will overwrite this one.-->
<AerodromeSettings>
    <DefaultAerodromes>
		<Aerodrome>NZAA</Aerodrome>
		<Aerodrome>NZWN</Aerodrome>
		<Aerodrome>NZCH</Aerodrome>
		<Aerodrome>NZQN</Aerodrome>
		<Aerodrome>NZDN</Aerodrome>
		<Aerodrome>NZPM</Aerodrome>
		<Aerodrome>NZTG</Aerodrome>
		<Aerodrome>NZRO</Aerodrome>
	</DefaultAerodromes>
  <UseNose>true</UseNose>
  <LayoutDefinitions>
    <!-- DEFAULT / RADAR TOWERS -->
    <LayoutDefinition Name="DEL">
      <Element Name="VFR Pending" Column="0" Weight="1.4"/>
      <Element Name="Pending" Column="0" Weight="1.8"/>
      <Element Name="Cleared" Column="1" Weight="1"/>
      <Element Name="Taxi" Column="2" Weight="1"/>
      <Element Name="Apron/Ground" Column="2" Weight="1"/>
    </LayoutDefinition>
    <LayoutDefinition Name="GND">
      <Element Name="Taxi" Column="0" Weight="1"/>
      <Element Name="Apron/Ground" Column="1" Weight="1"/>
      <Element Name="Runway" Column="2" Weight="1"/>
    </LayoutDefinition>
    <LayoutDefinition Name="GND+DEL">
      <Element Name="VFR Pending" Column="0" Weight="1.3"/>
      <Element Name="Pending" Column="0" Weight="1.8"/>
      <Element Name="Cleared" Column="1" Weight="0.9"/>
      <Element Name="Taxi" Column="1" Weight="1.1"/>
      <Element Name="Apron/Ground" Column="2" Weight="1"/>
      <Element Name="Runway" Column="2" Weight="1"/>
    </LayoutDefinition>
    <LayoutDefinition Name="TWR">
      <Element Name="West North VFR" Column="0" Weight="0.55"/>
      <Element Name="IFR Arrivals" Column="0" Weight="1.45"/>
      <Element Name="Runway" Column="1" Weight="1"/>
      <Element Name="East South VFR" Column="2" Weight="0.55"/>
      <Element Name="Apron/Ground" Column="2" Weight="0.95"/>
    </LayoutDefinition>
    <LayoutDefinition Name="GND+TWR">
      <Element Name="West North VFR" Column="0" Weight="0.5"/>
      <Element Name="IFR Arrivals" Column="0" Weight="1.25"/>
      <Element Name="Taxi" Column="0" Weight="0.9"/>
      <Element Name="Runway" Column="1" Weight="1"/>
      <Element Name="East South VFR" Column="2" Weight="0.5"/>
      <Element Name="Apron/Ground" Column="2" Weight="1.1"/>
    </LayoutDefinition>
    <LayoutDefinition Name="All">
      <Element Name="West North VFR" Column="0" Weight="0.45"/>
      <Element Name="Taxi" Column="0" Weight="0.85"/>
      <Element Name="VFR Pending" Column="0" Weight="1.7"/>
      <Element Name="IFR Arrivals" Column="1" Weight="0.5"/>
      <Element Name="Runway" Column="1" Weight="1"/>
      <Element Name="East South VFR" Column="2" Weight="0.45"/>
      <Element Name="Pending" Column="2" Weight="1.85"/>
      <Element Name="Cleared" Column="2" Weight="0.65"/>
      <Element Name="Apron/Ground" Column="2" Weight="0.75"/>
    </LayoutDefinition>
    <!-- METRO D -->
    <LayoutDefinition Name="All" Type="D">
      <Element Name="Preactive" Column="0"/>
      <Element Name="Taxi" Column="0"/>
      <Element Name="Holding Point" Column="1"/>
      <Element Name="Runway" Column="1"/>
      <Element Name="Circuit" Column="2"/>
      <Element Name="Arrivals" Column="2"/>
    </LayoutDefinition>
    <!-- PROC -->
    <LayoutDefinition Name="All" Type="Proc">
      <Element Name="Preactive" Column="0"/>
      <Element Name="Cleared" Column="0"/>
      <Element Name="Taxi" Column="1"/>
      <Element Name="Holding Point" Column="1"/>
      <Element Name="Runway" Column="1"/>
      <Element Name="Active" Column="2"/>
      <Element Name="Pending Arrivals" Column="2"/>
    </LayoutDefinition>
    <LayoutDefinition Name="SMC" Type="Proc">
      <Element Name="Preactive" Column="0"/>
      <Element Name="Cleared" Column="0"/>
      <Element Name="Taxi" Column="1"/>
      <Element Name="Holding Point" Column="2"/>
      <Element Name="Runway" Column="2"/>
    </LayoutDefinition>
    <LayoutDefinition Name="ADC" Type="Proc">
      <Element Name="Taxi" Column="0"/>
      <Element Name="Holding Point" Column="0"/>
      <Element Name="Runway" Column="1"/>
      <Element Name="Active" Column="2"/>
      <Element Name="Pending Arrivals" Column="2"/>
    </LayoutDefinition>
  </LayoutDefinitions>
  <BayTypes>
    <!-- RADAR TOWER / DEFAULT -->
    <BayType>
      <Bay Name="Pending">
        <Type>BAY_PREA</Type>
      </Bay>
      <Bay Name="Preactive">
        <Type>BAY_PREA</Type>
      </Bay>
      <Bay Name="VFR Pending">
        <Type>BAY_VFR_PENDING</Type>
      </Bay>
      <Bay Name="West North VFR">
        <Type>BAY_VFR_WEST_NORTH</Type>
      </Bay>
      <Bay Name="East South VFR">
        <Type>BAY_VFR_EAST_SOUTH</Type>
      </Bay>
      <Bay Name="Cleared">
        <Type>BAY_CLEARED</Type>
		<Type>BAY_COORDINATOR</Type>
      </Bay>
	  <Bay Name="Monitor SMC" Coordinator="true">
		  <Type>BAY_COORDINATOR</Type>
	  </Bay>
      <Bay Name="Pushback">
        <Type>BAY_PUSHED</Type>
      </Bay>
      <Bay Name="Apron/Ground">
        <Type>BAY_PUSHED</Type>
      </Bay>
      <Bay Name="Taxi">
        <Type>BAY_TAXI</Type>
      </Bay>
      <Bay Name="Holding Point">
        <Type>BAY_HOLDSHORT</Type>
      </Bay>
      <Bay Name="Runway" CDMDisplay="false">
        <Type>BAY_RUNWAY</Type>
      </Bay>
      <Bay Name="Departed">
        <Type>BAY_OUT</Type>
        <Type>BAY_CIRCUIT</Type>
      </Bay>
      <Bay Name="Circuit" Circuit="true">
        <Type>BAY_CIRCUIT</Type>
      </Bay>
      <Bay Name="IFR Arrivals">
        <Type>BAY_ARRIVAL</Type>
      </Bay>
      <Bay Name="Arrivals">
        <Type>BAY_ARRIVAL</Type>
      </Bay>
    </BayType>
    <!-- METROD -->
    <BayType Type="D">
      <Bay Name="Preactive">
        <Type>BAY_PREA</Type>
      </Bay>
      <Bay Name="Taxi">
        <Type>BAY_CLEARED</Type>
        <Type>BAY_PUSHED</Type>
        <Type>BAY_COORDINATOR</Type>
        <Type>BAY_TAXI</Type>
      </Bay>
      <Bay Name="Holding Point">
        <Type>BAY_HOLDSHORT</Type>
      </Bay>
      <Bay Name="Runway">
        <Type>BAY_RUNWAY</Type>
      </Bay>
      <Bay Name="Circuit">
        <Type>BAY_CIRCUIT</Type>
        <Type>BAY_OUT</Type>
      </Bay>
      <Bay Name="Arrivals">
        <Type>BAY_ARRIVAL</Type>
      </Bay>
    </BayType>
    <!-- PROC -->
    <BayType Type="Proc">
      <Bay Name="Preactive">
        <Type>BAY_PREA</Type>
      </Bay>
      <Bay Name="Cleared">
        <Type>BAY_CLEARED</Type>
      </Bay>
      <Bay Name="Taxi">
        <Type>BAY_PUSHED</Type>
        <Type>BAY_TAXI</Type>
        <Type>BAY_COORDINATOR</Type>
      </Bay>
      <Bay Name="Holding Point">
        <Type>BAY_HOLDSHORT</Type>
      </Bay>
      <Bay Name="Runway">
        <Type>BAY_RUNWAY</Type>
      </Bay>
      <Bay Name="Active">
        <Type>BAY_CIRCUIT</Type>
        <Type>BAY_OUT</Type>
      </Bay>
      <Bay Name="Pending Arrivals">
        <Type>BAY_ARRIVAL</Type>
      </Bay>
    </BayType>
  </BayTypes>
  <AerodromeLists>
    <AerodromeList Type="D">
      <Aerodrome>YBAF</Aerodrome>
      <Aerodrome>YMAV</Aerodrome>
      <Aerodrome>YSBK</Aerodrome>
      <Aerodrome>YSCN</Aerodrome>
      <Aerodrome>YMHB</Aerodrome>
      <Aerodrome>YPJT</Aerodrome>
      <Aerodrome>YMLT</Aerodrome>
      <Aerodrome>YBMK</Aerodrome>
      <Aerodrome>YPPF</Aerodrome>
      <Aerodrome>YBRK</Aerodrome>
      <Aerodrome>YMMB</Aerodrome>
    </AerodromeList>
    <AerodromeList Type="Proc">
      <Aerodrome>YMAY</Aerodrome>
      <Aerodrome>YBAS</Aerodrome>
      <Aerodrome>YBRM</Aerodrome>
      <Aerodrome>YCFS</Aerodrome>
      <Aerodrome>YBHM</Aerodrome>
      <Aerodrome>YPKA</Aerodrome>
      <Aerodrome>YBSU</Aerodrome>
      <Aerodrome>YSTW</Aerodrome>
      <Aerodrome>YPWR</Aerodrome>
    </AerodromeList>
  </AerodromeLists>
  <PDCFormat>PDC
{CALLSIGN}
CLEARED {TIMESTAMP} {ADES}
PDC DCL1 CLEARED TO {ADES} OFF {RWY} VIA {SID}
SQUAWK {SQUAWK}
NEXT FREQ {FREQ}
ATIS {ATIS}
TRANSITION:SEE SID ROUTE:{ROUTE}
ALT:{ALT}</PDCFormat>
  <AerodromeAutoFillLocation>AutoFill</AerodromeAutoFillLocation>
  <StripColour Type="ARRIVAL">#e6aedd</StripColour>
  <StripColour Type="DEPARTURE">#c1e6f2</StripColour>
  <StripColour Type="LOCAL">#ffffa0</StripColour>
  <StripColour Type="UNKNOWN">#404040</StripColour>
  <DefaultLayout>All</DefaultLayout>
</AerodromeSettings>
